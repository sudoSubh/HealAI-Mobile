# ─── Gemini AI (3 Keys for task-specific rotation) ───────────────────────────
EXPO_PUBLIC_GEMINI_KEY_1=your_gemini_api_key_1_here
EXPO_PUBLIC_GEMINI_KEY_2=your_gemini_api_key_2_here
EXPO_PUBLIC_GEMINI_KEY_3=your_gemini_api_key_3_here

# ─── Sarvam AI (STT / TTS / Translation) ─────────────────────────────────────
EXPO_PUBLIC_SARVAM_API_KEY=your_sarvam_subscription_key_here

# ─── Neo4j Aura DB ───────────────────────────────────────────────────────────
EXPO_PUBLIC_NEO4J_HOST=xxxxxxxx.databases.neo4j.io
EXPO_PUBLIC_NEO4J_DATABASE=xxxxxxxx
EXPO_PUBLIC_NEO4J_USER=neo4j
EXPO_PUBLIC_NEO4J_PASSWORD=your_neo4j_password_here

# ─── Voice Server (ngrok/tunnel URL of HealAI-Voice-Server) ──────────────────
EXPO_PUBLIC_VOICE_SERVER_URL=https://your-tunnel-url.ngrok-free.app
